<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Training Portal' %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <% if (typeof isLanding !== 'undefined' && isLanding) { %>
        <h1 class="logo"><a href="/" class="logo-link">Training Portal</a></h1>
        <% } else { %>
        <% if (typeof username !== 'undefined' && username) { %>
        <span class="header-user">Signed in as <strong><%= username %></strong></span>
        <% } %>
        <h1 class="logo"><a href="/" class="logo-link">Training Portal</a></h1>
        <nav>
          <ul>
            <% if (typeof username !== 'undefined' && username) { %>
            <li>
              <form action="/logout" method="post" class="nav-form">
                <button type="submit">Logout</button>
              </form>
            </li>
            <% } else { %>
            <li><a href="/forgot">Forgot Password</a></li>
            <% } %>
          </ul>
        </nav>
        <% } %>
      </div>
    </header>
    <main class="container<%= typeof isAuthPage !== 'undefined' && isAuthPage ? ' main--auth' : '' %>">
      <%- body %>
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>Intentionally vulnerable training app. Do not use in production.</p>
      </div>
    </footer>
    <script src="/js/app.js"></script>
  </body>
</html>

